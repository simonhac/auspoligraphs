  "preferenceFlows": {
    "matrix": {
      "grn": {
        "source": "Composite of (a) Vic 2022 measured Samiotis/Albert Park R6 exclusion (alp 84% / lib 16%, 8,488/1,639 of 10,127) and (b) SA 2026 ALP-vs-ONP finals (10-seat sample: alp 81% / onp 19%, per Antony Green rolling summary). Row calibrated so leftover-redistribution under `lib/seats/irv.ts:75-87` produces ~85/15 in ALP-vs-Lib 2CPs and ~80/20 in ALP-vs-ONP 2CPs.",
        "assumption": "Grn → ALP 75% / Lib 5% / ONP 15% / Oth 5%. Reserves an explicit ONP destination at 15% so seats where ONP is in the final 2CP don't rely on leftover-redistribution alone (which under-credited ONP). In ALP-vs-Lib finals where ONP is absent, the 15% reservation re-spreads via leftover across survivors and reproduces the 85/15 split.",
        "measured": true,
        "flows": {
          "alp": 0.75,
          "lib": 0.05,
          "onp": 0.15,
          "oth": 0.05
        }
      },
      "oth": {
        "source": "Conventional psephology estimate, not measured for 2022 in this revision (would require aggregating exclusion rounds for ONP/UAP/FFV/LDP/AJP/Reason/LegalCannabis across many seats).",
        "assumption": "Other/minor → ALP 44% / Lib 40% / Nat 8% / Grn 8% (proportional renormalisation of the earlier 42/38/8/8/4 split that included a meaningless 4% Oth→Oth self-loop; self-loops are filtered out of IRV redistribution in lib/seats/irv.ts and rendered as the diagonal in the UI matrix, so they don't contribute to the row sum).",
        "measured": false,
        "flows": {
          "alp": 0.44,
          "lib": 0.4,
          "nat": 0.08,
          "grn": 0.08
        }
      },
      "nat": {
        "source": "Proxied from SA2026 Lib→ONP measurement (no direct Nat→ONP data: only 3 Nat candidates ran in SA 2026, all polling too poorly for their exclusions to yield a clean flow estimate). Assumed slightly higher than Lib's 68% on the basis that Nat voters are rural-skewed and at least as ONP-friendly as Liberals; plausible band 65–80%, midpoint chosen.",
        "assumption": "Nat → ONP 70% / Lib 22% / ALP 6% / Grn 1% / Oth 1% (post-Hopper realignment). Per-seat preferenceOverrides on the 6 Vic 2022 country 3-corner seats (bass, euroa, mildura, morwell, narracan, shepparton) preserve the prior Nat → Lib 82% Coalition-partner flow in seats where Lib actually stands as Nat's Coalition opponent.",
        "measured": false,
        "flows": {
          "onp": 0.7,
          "lib": 0.22,
          "alp": 0.06,
          "grn": 0.01,
          "oth": 0.01
        }
      },
      "lib": {
        "source": "SA2026 aggregate: Liberal preferences flowed to One Nation at ~68% across 7 ALP-vs-ONP final contests (range 53% Enfield → 73.5% Hammond). Liberal HTV cards directed ONP > ALP in every SA 2026 seat — a post-Hopper realignment from the 2022 status quo. Sources: Antony Green rolling SA2026 summary (https://antonygreen.com.au/sa2026-updating-result-summary/); Ben Raue / Tally Room (https://www.tallyroom.com.au/64676); Murray Bridge News (Hammond 73.5%).",
        "assumption": "Lib → ONP 68% / ALP 30% / Grn 1% / Oth 1% (SA2026-style realignment). Replaces the 2022 measured Morwell+Euroa composite (Lib → Nat 88% / ALP 12%), which was specific to country 3-corner Lib-vs-Nat contests; that flow is preserved via per-seat preferenceOverrides on bass, euroa, mildura, morwell, narracan, shepparton where the Coalition-partner dynamic still dominates.",
        "measured": true,
        "flows": {
          "onp": 0.68,
          "alp": 0.3,
          "grn": 0.01,
          "oth": 0.01
        }
      },
      "alp": {
        "source": "Conventional psephology estimate. ALP was rarely excluded in the DoPs sampled (mostly the major-party making 2CP), and when excluded (e.g. Schween/Mornington round 3 with only 822 votes) the round had too many remaining candidates to give a clean ALP→{Grn,Lib} split.",
        "assumption": "ALP (if excluded) → Grn 55% / Lib 20% / Nat 8% / Oth 17%",
        "measured": false,
        "flows": {
          "grn": 0.55,
          "lib": 0.2,
          "nat": 0.08,
          "oth": 0.17
        }
      },
      "onp": {
        "source": "Composite of (a) AEC 2025 federal TPP preference flow table (ONP → L/NP 74.50% / ALP 25.50%, 252,917 ONP TPP votes in classic ALP-vs-LNP seats — https://results.aec.gov.au/31496/Website/HouseStateTppFlow-31496-NAT.htm); (b) Antony Green's SA 2026 rolling result summary (6 Lab-vs-Lib finals where ONP was last excluded: Lib 69% / ALP 31% — https://antonygreen.com.au/sa2026-updating-result-summary/); (c) 2022 VEC LA DoPs where ONP was excluded in Bendigo East, Macedon, Morwell (small N; ONP polled only 0.22% LA statewide in 2022). The 74.5% federal Coalition share is split into Lib and Nat on the assumption most VIC ONP-strong seats are metro/regional non-3-corner contests where only Lib runs; Nat share kept small and concentrated onto country 3-corner seats via per-seat preferenceOverrides.",
        "assumption": "One Nation → Lib 67% / Nat 2% / ALP 27% / Grn 2% / Teal 1% / Oth 1% (Coalition aggregate 69%, matching SA 2026 6-seat ALP-vs-Lib final measurement of 69/31). Nudged from prior 70/22 split: ALP up to 27% (closer to SA's 31% but kept below it because the SA sample is biased to seats where ALP primary was unusually low), Coalition share down a touch. Nat reservation shrunk to 2% (most ONP-strong Vic seats are metro/regional non-3-corner contests; Nat share will be re-routed by leftover redistribution in the few country seats). Teal 1% reflects that a handful of ONP voters put community indies above Labor/Greens; auto-normalised away by IRV in seats without a teal candidate.",
        "measured": false,
        "flows": {
          "lib": 0.67,
          "nat": 0.02,
          "alp": 0.27,
          "grn": 0.02,
          "ind_teal": 0.01,
          "oth": 0.01
        }
      },
      "ind_teal": {
        "source": "https://www.vec.vic.gov.au/results/state-election-results/2022-state-election-results/results-by-district/hawthorn-district-results/hawthorn-results-distribution + .../kew-district-results/kew-results-distribution + corroborating: .../mornington-district-results/mornington-results-distribution (Grn→Lardner 83.8% in round 6, consistent with Lardner being a progressive-leaning indie)",
        "assumption": "Teal → ALP 75% / Lib 25% (measured composite from Hawthorn + Kew: Lowe 9,219/2,839 of 12,058; Torney 8,379/3,092 of 11,471 — weighted 17,598/5,931 of 23,529 → ALP 74.8% / Lib 25.2%). Greens already excluded in both measured contests; small Grn share reserved on the assumption some teal voters had Grn above Lib. Lardner/Mornington made 2CP so her own flows are unobservable — proxied via Hawthorn+Kew; the Grn→Lardner 84% flow in Mornington corroborates her teal profile.",
        "measured": true,
        "flows": {
          "alp": 0.72,
          "lib": 0.23,
          "grn": 0.04,
          "oth": 0.01
        }
      },
      "ind_country": {
        "source": "Proxied from Altmann (South-West Coast) measured flow + community-indie convention. Direct measurement impossible: Hawkins (Benambra), Cupper (Mildura) and Sheed (Shepparton) all made 2CP in their seats, so their preferences were never distributed.",
        "assumption": "Country indie → ALP 55% / Lib 22% / Nat 15% / Grn 5% / Oth 3% (Altmann-shaped, with Nat share added since these contests are 3-cornered Coalition).",
        "measured": false,
        "flows": {
          "alp": 0.55,
          "lib": 0.22,
          "nat": 0.15,
          "grn": 0.05,
          "oth": 0.03
        }
      }
    }
  },
